# =============================================================================
# Lockso — Environment Configuration
# Copy this file to .env and adjust values for your environment.
# =============================================================================

# --- Application ---
LOCKSO_BIND=0.0.0.0:8080
LOCKSO_ENV=development
LOCKSO_LOG_LEVEL=debug
LOCKSO_DEFAULT_LANGUAGE=en
LOCKSO_DEFAULT_TIMEZONE=UTC
APP_URL=http://localhost:5173

# --- Database Pool ---
# DATABASE_MAX_CONNECTIONS=20

# --- PostgreSQL 18 ---
DATABASE_URL=postgres://lockso:lockso_secret@postgres:5432/lockso
POSTGRES_USER=lockso
POSTGRES_PASSWORD=lockso_secret
POSTGRES_DB=lockso

# --- Redis 7 ---
REDIS_URL=redis://redis:6379

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lockso-files

# --- SMTP (email) ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@lockso.example.com
# SMTP_TLS=true

# --- Encryption ---
# Server-side encryption key for item fields (64 hex chars = 32 bytes AES-256-GCM).
# Generate with: openssl rand -hex 32
# Required in production. Dev uses a deterministic fallback key if not set.
# LOCKSO_ENCRYPTION_KEY=

# --- Session ---
# SESSION_SECRET=  (auto-generated on first run if empty)
# SESSION_TTL_HOURS=24

# --- Rate Limiting ---
# RATE_LIMIT_LOGIN_PER_MINUTE=5
# RATE_LIMIT_API_PER_MINUTE=120
